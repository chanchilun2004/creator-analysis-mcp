# Backend API (server-side only, never exposed to clients)
CREATOR_API_BASE=https://tryeat-test-api.goodmalling.io
CREATOR_API_KEY=replace-me

# Comma-separated list of accepted client tokens (one per user)
MCP_ACCESS_TOKENS=token-for-user-a,token-for-user-b

# Fail-closed: with MCP_ACCESS_TOKENS empty the endpoint rejects all requests.
# Set ALLOW_OPEN=1 only if you intentionally want an unauthenticated endpoint.
ALLOW_OPEN=0

# Per-token requests/minute cap (basic abuse/cost guard). Default 30.
RATE_LIMIT_PER_MIN=30

# HMAC secret for OAuth-issued access tokens (set a long random value in production;
# falls back to a hash of CREATOR_API_KEY if unset — rotating the key then kills sessions)
OAUTH_SIGNING_SECRET=replace-with-long-random-string

PORT=8080
